{
  "name": "@uncaughtdev/react",
  "version": "0.1.0",
  "description": "React and Next.js SDK for Uncaught error monitoring",
  "license": "MIT",
  "author": "Uncaught",
  "repository": {
    "type": "git",
    "url": "https://github.com/AjeeshDevops/uncaught.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/AjeeshDevops/uncaught#readme",
  "keywords": [
    "react",
    "error-boundary",
    "error-monitoring",
    "nextjs",
    "debugging",
    "vibe-coding"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "@uncaughtdev/core": "workspace:*"
  },
  "dependencies": {
    "@uncaughtdev/core": "workspace:*"
  },
  "devDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@testing-library/react": "^15.0.0"
  }
}
