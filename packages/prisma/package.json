{
  "name": "@uncaughtdev/prisma",
  "version": "0.1.0",
  "description": "Prisma error tracking wrapper for Uncaught — captures failed queries, constraint violations, and model operations",
  "license": "MIT",
  "author": "Uncaught",
  "repository": {
    "type": "git",
    "url": "https://github.com/AjeeshDevops/uncaught.git",
    "directory": "packages/prisma"
  },
  "homepage": "https://github.com/AjeeshDevops/uncaught#readme",
  "keywords": [
    "prisma",
    "error-monitoring",
    "query-tracking",
    "database",
    "debugging"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@prisma/client": ">=4.0.0",
    "@uncaughtdev/core": "workspace:*"
  },
  "dependencies": {
    "@uncaughtdev/core": "workspace:*"
  },
  "devDependencies": {
    "@prisma/client": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
