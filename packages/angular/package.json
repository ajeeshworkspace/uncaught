{
  "name": "@uncaughtdev/angular",
  "version": "0.1.0",
  "description": "Angular SDK for Uncaught error monitoring",
  "license": "MIT",
  "author": "Uncaught",
  "repository": {
    "type": "git",
    "url": "https://github.com/AjeeshDevops/uncaught.git",
    "directory": "packages/angular"
  },
  "homepage": "https://github.com/AjeeshDevops/uncaught#readme",
  "keywords": [
    "angular",
    "error-monitoring",
    "error-handler",
    "debugging",
    "vibe-coding"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0",
    "@angular/common": ">=16.0.0",
    "@uncaughtdev/core": "workspace:*"
  },
  "dependencies": {
    "@uncaughtdev/core": "workspace:*"
  },
  "devDependencies": {
    "@angular/core": "^17.0.0",
    "@angular/common": "^17.0.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
